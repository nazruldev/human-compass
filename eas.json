{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote",
        "simulator": false
      },
      "android": {
        "distribution": "store",
        "image": "latest"
      },
      "developmentClient": false
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "appleTeamId": "L28RC7UMG3",
        "appleId": "nazrul.dev@gmail.com",
        "ascAppId": "6761703980"
      }
    }
  }
}
